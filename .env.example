# ===========================================
# Hostly - משתני סביבה להרצה מקומית
# העתק לקובץ .env.local והשלם ערכים אמיתיים
# ===========================================

# --- חובה להפעלת האפליקציה ---
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (התחברות עם חשבון גוגל)
# צור App ב: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI לפיתוח:  http://localhost:3000/api/auth/callback/google
# Authorized redirect URI לפרודקשיין: https://app.hostly.co.il/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# פרודקשיין (Vercel): המערכת רצה על app.hostly.co.il
# NEXTAUTH_URL=https://app.hostly.co.il
# NEXT_PUBLIC_APP_URL=https://app.hostly.co.il

# Supabase (חובה - הקוד נכשל בלי אלה)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase - פעולות אדמין (להזמנות, משתמשים וכו')
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- BEDS24 API V2 (לדשבורד, חדרים, מחירים) ---
BEDS24_API_BASE_URL=https://api.beds24.com/v2
BEDS24_TOKEN=your_beds24_v2_token
BEDS24_REFRESH_TOKEN=your_beds24_refresh_token

# אופציונלי - אם אין משתמש מחובר עם propertyId/roomId
# BEDS24_PROPERTY_ID=
# BEDS24_ROOM_ID=

# --- אופציונלי ---
# BEDS24_API_KEY=
# BEDS24_INCLUDE_AVAILABILITY=
# BEDS24_INVENTORY_START_DATE=
# BEDS24_INVENTORY_END_DATE=
# BEDS24_INVENTORY_QUERY=
# BEDS24_BOOKINGS_QUERY=

# Dashboard provider (ברירת מחדל: beds24)
# NEXT_PUBLIC_DASHBOARD_PROVIDER=beds24
# NEXT_PUBLIC_BEDS24_BASE_URL=

# WhatsApp (WHAPI)
# WHATSAPP_PROVIDER=auto
# WHAPI_TOKEN=
# WHAPI_BASE_URL=https://gate.whapi.cloud
# OWNER_PHONE_NUMBER=

# Seed דמו (רק development)
# SEED_DEMO_SECRET=

# --- Cron Jobs (Vercel Cron) ---
# סוד לאימות קריאות מתוזמנות מ-Vercel Cron (למשל /api/cron/review-reminders).
# Vercel שולח אוטומטית Authorization: Bearer <CRON_SECRET> כשמוגדר על הפרויקט.
# צרו ערך אקראי חזק, למשל: openssl rand -hex 32
CRON_SECRET=
